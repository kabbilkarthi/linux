#!/bin/bash

# Author: KABBIL GI

trap cleanup INT EXIT

MAX_PARALLEL=3

usage() {
  echo ""
  echo "USAGE: $0 [OPTIONS]"
  echo ""
  echo "  -m, --machine  <value>   Single host, comma-separated hosts, or path to a hostfile"
  echo "                           Examples:"
  echo "                             -m server01"
  echo "                             -m server01,server02,server03"
  echo "                             -m /path/to/hostfile.txt"
  echo ""
  echo "  -f, --farm     <value>   LSF farm name"
  echo "                           Example: -f prod_farm"
  echo ""
  echo "  -h, --help               Show this help message"
  echo ""
}


OPTIONS=$(getopt --options  m:f:h --longoptions  machine:,farm:,help --name "$0" -- "$@") \
|| { echo "Argument parsing failed. Use -h for help."; exit 1; }

eval set -- "$OPTIONS"

RAW_HOST=""
FARM=""

while true; do
  case "$1" in
    -m | --machine)
      RAW_HOST="$2"
      shift 2
      ;;
    -f | --farm)
      FARM="$2"
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      echo "Unexpected option: $1"
      usage
      exit 1
      ;;
  esac
done

if [ $# -gt 0 ]; then
  echo "ERROR: Unexpected positional argument(s): $*"
  usage
  exit 1
fi

declare -a HOSTS=()

if [ -n "$RAW_HOST" ]; then
  if [ -f "$RAW_HOST" ]; then
    while IFS= read -r line; do
      line=$(echo "$line" | xargs)
      [[ -z "$line" || "$line" == \#* ]] && continue
      HOSTS+=("$line")
    done < "$RAW_HOST"
  else
    IFS=', ' read -ra HOSTS <<< "$RAW_HOST"
  fi
fi

if [ "${#HOSTS[@]}" -eq 0 ] && [ -z "$FARM" ]; then
  usage; exit 1
fi

acquire_slot() {
  while true; do
    local running
    running=$(jobs -rp | wc -l)
    if (( running < MAX_PARALLEL )); then
      return 0
    fi
    wait -n 2>/dev/null || sleep 0.3
  done
}

run_parallel() {
  local remote_cmd="$1"
  local DATE
  DATE=$(date +%d-%m-%y)

  for h in "${HOSTS[@]}"; do
    acquire_slot
    (
      output=$(echo "===== $h =====";ssh -o ConnectTimeout=10 -o StrictHostKeyChecking=no -o LogLevel=ERROR \
            "$h" "$remote_cmd" 2>&1)
      local rc=$?
      if [ $rc -ne 255 ]; then
        echo "$output"
        echo
      else
        echo "$output"
        echo "[WARN] SSH exited with code $rc on $h"
        echo
      fi
    )  2>&1 | tee -a "${h}_${DATE}.log" &
  done
  wait
}

run_sequential() {
  local remote_cmd="$1"
  local DATE
  DATE=$(date +%d-%m-%y)

  for h in "${HOSTS[@]}"; do

    (
      echo "===== $h =====" 
      output=$(sudo ssh -t -o ConnectTimeout=10 -o StrictHostKeyChecking=no \
          -o LogLevel=ERROR "$h" "$remote_cmd" 2>&1)
        local rc=$?

        if [ $rc -ne 255 ]; then
          echo "$output"
          echo
        else
          echo "$output"
          echo "[WARN] SSH exited with code $rc on $h"
        fi
     ) 2>&1 | tee -a "${h}_${DATE}.log"
  done
}

srcfrm() {
  source /global/lsf/cells/"$1"/conf/profile.lsf
}

# ─────────────────────────────────────────────
# MENUS
# ─────────────────────────────────────────────
main_menu() {
  clear
  echo "-----------------------------------------------"
  printf "| %-43s |\n" "Main MENU"
  echo "-----------------------------------------------"
  printf "| %-20s | %-20s |\n" "1. Disk"    "2. Citrix"
  printf "| %-20s | %-20s |\n" "3. Process" "4. Exit"
  printf "| %-20s | %-20s |\n" "5. Farm"    "6. Login Restriction"
  printf "| %-20s | %-20s |\n" "7. Health Check" ""
  echo "-----------------------------------------------"
  echo
  read -rn 1 -p "Choose an option: " remote_opt
  echo
}

pause() {
  printf "\n%30s\n" "Hit Any Key To Continue"
  read -rn 1
}

require_hosts() {
  if [ "${#HOSTS[@]}" -eq 0 ]; then
    echo "ERROR: No host(s) specified. Use -m to pass hosts."
    return 1
  fi
  return 0
}

cleanup() {
    echo "Cleaning up..."
    kill 0
}

# ─────────────────────────────────────────────
# MAIN LOOP
# ─────────────────────────────────────────────
while true; do
  main_menu
  case $remote_opt in

    # ── 1. DISK ────────────────────────────────
    1)
      require_hosts || { pause; continue; }
      read -rp "Disk path: " DISK
      while [ -z "$DISK" ]; do
        read -rp "Please enter a disk path: " DISK
      done

      while true; do
        clear
        echo "-----------------------------------"
        printf "|         Disk MENU               |\n"
        echo "-----------------------------------"
        printf "| %-18s | %-7s |\n" "1. Main Menu"       "2. FS Size"
        printf "| %-18s | %-10s |\n" "3. Disk Usage Sort" "4. Exit"
        echo "-----------------------------------"
        printf "  Hosts (%d): %s\n" "${#HOSTS[@]}" "${HOSTS[*]}"
        echo
        read -rn 1 -p "Choose an option: " diskopt
        echo

        case $diskopt in
          1) break ;;
          2)
            echo "Checking FS size on ${#HOSTS[@]} host(s)"
            run_sequential "
              echo \"=== Filesystem Usage ===\"
              df -h $DISK
            "
            ;;
          3)
            echo "Running disk usage sort on ${#HOSTS[@]} host(s)"
            run_sequential "
              echo \"=== Disk Usage Summary ===\"
              du -shx $DISK
              echo \"=== High Space Consumption ===\"
              du -hxd1 $DISK | sort -rh | head
            "
            ;;
          4) exit 0 ;;
          *) echo "Invalid Option" ;;
        esac
        pause
      done
      continue
      ;;

    # ── 2. CITRIX ──────────────────────────────
    2)
      require_hosts || { pause; continue; }

      while true; do
        clear
        echo "----------------------------------"
        printf "|           ctx MENU             |\n"
        echo "----------------------------------"
        printf "| %-13s | %-14s |\n" "1. Main Menu"  "2. ctxqsession"
        printf "| %-13s | %-14s |\n" "3. ctxreset"   "4. Exit"
        printf "| %-13s |\n"         "5. Reboot"
        echo "----------------------------------"
        printf "  Hosts (%d): %s\n" "${#HOSTS[@]}" "${HOSTS[*]}"
        echo
        read -rn 1 -p "Choose an option: " citrixopt
        echo

        case $citrixopt in
          1) break ;;

          2)
            echo "[Sequential] Querying ctxqsession on ${#HOSTS[@]} host(s)"
            run_sequential "
              echo \"=== User Sessions ===\"
              ctxqsession
            "
            ;;

          # ── ctxreset: SEQUENTIAL (interactive per-host) ──
          3)
            echo "[Sequential] ctxreset runs one host at a time to avoid session ID collisions."
            DATE=$(date +%d-%m-%y)
            for h in "${HOSTS[@]}"; do
              echo
              echo "===== $h ====="
              read -rp "  Session ID to reset on $h: " SESSION_ID
              while [ -z "$SESSION_ID" ]; do
                read -rp "  Session ID cannot be empty: " SESSION_ID
              done
              {
                ssh -t "$h" "
                  echo \"=== Applying ctxreset on session $SESSION_ID ===\"
                  ctxreset :$SESSION_ID
                "
              } 2>&1 | tee -a "${h}_${DATE}.log"
            done
            ;;

          4) exit 0 ;;

          5)
            echo "[Sequential] Rebooting ${#HOSTS[@]} host(s)"
            read -rp "Are you sure you want to reboot ${#HOSTS[@]} host(s)? [yes/no]: " confirm
            if [[ "$confirm" == "yes" || "$confirm" == "y" || "$confirm" == "Y" ]]; then
              run_sequential "
                echo \"=== Applying Reboot ===\"
                sudo shutdown -r now
              "
            else
              echo "Reboot cancelled."
            fi
            ;;

          *) echo "Invalid Option" ;;
        esac
        pause
      done
      continue
      ;;

    # ── 3. PROCESS ─────────────────────────────
    3)
      require_hosts || { pause; continue; }

      while true; do
        clear
        echo "----------------------------------------"
        printf "|        Process MENU                  |\n"
        echo "----------------------------------------"
        printf "| %-18s | %-9s |\n" "1. Main Menu"       "2. Uptime/Cores"
        printf "| %-15s | %-15s |\n" "3. D-State Process" "4. Exit"
        echo "----------------------------------------"
        printf "  Hosts (%d): %s\n" "${#HOSTS[@]}" "${HOSTS[*]}"
        echo
        read -rn 1 -p "Choose an option: " procopt
        echo

        case $procopt in
          1) break ;;
          2)
            echo "[Sequential] Checking uptime/cores on ${#HOSTS[@]} host(s)"
            run_sequential "
              echo \"=== Uptime ===\"
              uptime
              echo \"=== CPU Cores ===\"
              nproc
            "
            ;;
          3)
            echo "[Sequential] Checking D-State processes on ${#HOSTS[@]} host(s)"
            run_sequential "
              if ps -eo user,pid,s | grep -wi d >/dev/null 2>&1; then
                echo \"=== D-State Processes ===\"
                ps -eo user,pid,s | grep -wi d
              else
                echo \"No D-State processes found.\"
              fi
            "
            ;;
          4) exit 0 ;;
          *) echo "Invalid Option" ;;
        esac
        pause
      done
      continue
      ;;

    # ── 4. EXIT ────────────────────────────────
    4)
      exit 0
      ;;

    # ── 5. FARM ────────────────────────────────
    5)
      if [ -z "$FARM" ]; then
        read -rp "Enter FARM name: " FARM
        while [ -z "$FARM" ]; do
          read -rp "FARM cannot be empty. Enter FARM name: " FARM
        done
      fi

      while true; do
        clear
        echo "---------------------------------------"
        printf "|         Farm MENU                   |\n"
        echo "---------------------------------------"
        printf "| %-15s | %-17s |\n" "1. Main Menu"  "2. Pending reason"
        printf "| %-15s | %-17s |\n" "3. User Limit" "4. Exit"
        echo "---------------------------------------"
        echo "  Farm: $FARM"
        echo
        read -rn 1 -p "Choose an option: " farmopt
        echo

        case $farmopt in
          1) break ;;
          2)
            DATE=$(date +%d-%m-%y)
            {
              echo "Sourcing farm: $FARM"
              srcfrm "$FARM"
              read -rp "User ID: " user
              echo -e "\nRunning Jobs:"
              bjobs -u "$user"
              read -rp "Check pending reason? [yes/no]: " ans
              while [ -z "$ans" ]; do
                read -rp "Please confirm yes/no: " ans
              done
              if [[ "$ans" == "yes" || "$ans" == "y" || "$ans" == "Y" ]]; then
                read -rp "Job ID: " jobid
                bjobs -l "$jobid"
              fi
            } 2>&1 | tee -a "${FARM}_${DATE}.log"
            ;;
          3)
            DATE=$(date +%d-%m-%y)
            {
              echo "Sourcing farm: $FARM"
              srcfrm "$FARM"
              read -rp "User ID: " user
              echo -e "\nUser Limits:"
              blimits -u "$user"
            } 2>&1 | tee -a "${FARM}_${DATE}.log"
            ;;
          4) exit 0 ;;
          *) echo "Invalid Option" ;;
        esac
        pause
      done
      continue
      ;;

    # ── 6. LOGIN RESTRICTION ───────────────────
    6)
      require_hosts || { pause; continue; }

      while true; do
        clear
        echo "------------------------------------------"
        printf "|  Login Restriction MENU                |\n"
        echo "------------------------------------------"
        printf "| %-15s | %-20s |\n" "1. Main Menu"     "2. Show Restrictions"
        printf "| %-15s | %-20s |\n" "3. Search User"   "4. Exit"
        echo "------------------------------------------"
        printf "  Hosts (%d): %s\n" "${#HOSTS[@]}" "${HOSTS[*]}"
        echo
        read -rn 1 -p "Choose an option: " loginopt
        echo

        case $loginopt in
          1) break ;;
          2)
            echo "[Sequential] Checking login restrictions on ${#HOSTS[@]} host(s)"
            run_sequential "
              echo \"=== Login Restrictions (/etc/security/access.conf) ===\"
              tail -n 4 /etc/security/access.conf
            "
            ;;
          3)
            read -rp "Enter username to search: " search
            while [ -z "$search" ]; do
              read -rp "Username cannot be empty: " search
            done
            echo "[Sequential] Searching '$search' on ${#HOSTS[@]} host(s)"
            run_sequential "
              echo \"=== Searching for '$search' in access.conf ===\"
              grep -wi '$search' /etc/security/access.conf || echo 'No match found.'
            "
            ;;
          4) exit 0 ;;
          *) echo "Invalid Option" ;;
        esac
        pause
      done
      continue
      ;;

    # ── 7. HEALTH CHECK ────────────────────────
    7)
      require_hosts || { pause; continue; }

      while true; do
        clear
        echo "-----------------------------------------------"
        printf "|          Health check MENU                  |\n"
        echo "-----------------------------------------------"
        printf "| %-20s | %-20s |\n" "1. Main Menu"          "2. Health Check - LS"
        printf "| %-20s | %-20s |\n" "3. Health Check - SS"  "4. Exit"
        echo "-----------------------------------------------"
        printf "  Hosts (%d): %s\n" "${#HOSTS[@]}" "${HOSTS[*]}"
        echo
        read -rn 1 -p "Choose an option: " healthopt
        echo

        case $healthopt in
          1) break ;;
          2)
            echo "[Sequential] Running LS health check on ${#HOSTS[@]} host(s)"
            run_sequential "
              echo \"=== Health Check (LS) ===\"
              /etc/synopsys/local_health_check/bin/local_health_check.sh -v
            "
            ;;
          3)
            echo "[Sequential] Running SS health check on ${#HOSTS[@]} host(s)"
            run_sequential "
              echo \"=== Health Check (SS) ===\"
              ckhealth.ksh -v
            "
            ;;
          4) exit 0 ;;
          *) echo "Invalid Option" ;;
        esac
        pause
      done
      continue
      ;;

    *) echo "Invalid Option" ;;
  esac
  pause
done
